        "element.disabled": "#1a1a1a",
        "drop_target.background": "#5996db40",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#222222",
        "ghost_element.active": "#2b2b2b",
        "ghost_element.selected": "#2b2b2b",
        "ghost_element.disabled": "#1a1a1a",

        "text": "#d4d4d4",
